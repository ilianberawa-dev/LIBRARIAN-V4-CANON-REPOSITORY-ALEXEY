# ═════════════════════════════════════════════════════════════
# Realty Portal — ЕДИНЫЙ СЕЙФ СЕКРЕТОВ
#
# Это ЕДИНСТВЕННЫЙ файл, где живут значения ключей и токенов.
# - На сервере:  /opt/realty-portal/.env  (chmod 600 root:root)
# - На ноутбуке: realty-portal/.env       (gitignored, копия для разработки)
#
# Любая программа, которой нужен секрет, читает ИЗ ЭТОГО ФАЙЛА:
#   • Docker-сервисы        — через `env_file: .env` в docker-compose.yml
#   • backup.sh/migrate.sh  — через `source .env`
#   • Claude Code MCP       — через scripts/claude-env-remote.sh
#                              (SSH тянет .env с сервера в shell локально,
#                               на диск ноутбука секреты не пишутся)
#
# НИКОГДА не хранить ключи в других местах — ни в коде, ни в
# скиллах, ни в docs/, ни в docker-compose.yml, ни в /root/.env,
# ни в ~/.claude.json.
#
# Обновление любого ключа — ОДНО действие:
#   1. Заменить значение в /opt/realty-portal/.env
#   2. `cd /opt/realty-portal/ && docker compose up -d --force-recreate`
#
# ═════════════════════════════════════════════════════════════

# ── Общие ────────────────────────────────────────────────────
# IP сервера Aeza (пока без домена — будет доступ через SSH-tunnel)
PORTAL_HOST=193.233.128.21

# ── Supabase self-hosted (генерируется при установке) ────────
# Берётся из официального шаблона supabase/docker/.env.example и
# переносится сюда. Все эти значения уникальны для нашей инсталляции
# и не должны совпадать с дефолтными из публичных примеров.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM
ANON_KEY=CHANGE_ME_GENERATED_FROM_JWT
SERVICE_ROLE_KEY=CHANGE_ME_GENERATED_FROM_JWT
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=CHANGE_ME

# ── LightRAG ─────────────────────────────────────────────────
LIGHTRAG_API_KEY=CHANGE_ME_INTERNAL
LIGHTRAG_LLM_MODEL=gpt-4.1-mini

# ── OpenClaw ─────────────────────────────────────────────────
OPENCLAW_MODE=self-hosted
OPENCLAW_API_KEY=
# Gateway token — OpenClaw Control UI auth (local 127.0.0.1:18789)
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_RANDOM_HEX_48
# MCP bridge shared secret — used by supabase-mcp-claude stdio
# Generate fresh for each install: `openssl rand -hex 32`
MCP_API_KEY=CHANGE_ME_RANDOM_HEX_64

# ── Модели для прод-скиллов (MiniMax или Qwen по канону) ─────
# Dev (Claude Code на ноуте) — свой ключ Anthropic
ANTHROPIC_API_KEY=
# Prod default (OpenClaw): один из этих, в зависимости от решения
MINIMAX_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# ── ЧТО НЕ добавлять в этот файл ─────────────────────────────
# ❌ TELEGRAM_BOT_TOKEN — канон Алексея запрещает Telegram на MVP
# ❌ OLLAMA_* — не используем (old brain-эра)
# ❌ PAPERCLIP_* — канон запрещает Paperclip
# Если что-то из этого случайно окажется в .env — значит, отошли
# от канона. Удалить.
