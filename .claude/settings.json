      "Bash(ping -c:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",

      "Bash(node --version)",
      "Bash(node -e:*)",
      "Bash(node -p:*)",
      "Bash(npm --version)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npm view:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(npm outdated:*)",
      "Bash(npm config get:*)",
      "Bash(npx:*)",

