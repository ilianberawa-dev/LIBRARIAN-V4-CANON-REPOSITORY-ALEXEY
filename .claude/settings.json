{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/session-start.sh"
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Read",
            "Glob",
            "Grep",
            "Edit",
            "Write",
            "Skill",
            "Bash(*)"
        ],
        "deny": [
            "Bash(rm *)",
            "Bash(rm -rf *)",
            "Bash(rm -f *)",
            "Bash(sudo *)",
            "Bash(chmod *)",
            "Bash(chown *)",
            "Bash(git push --force *)",
            "Bash(git push -f *)",
            "Bash(git reset --hard *)",
            "Bash(git clean -fd *)",
            "Bash(curl * | sh *)",
            "Bash(curl * | bash *)",
            "Edit(.git/**)",
            "Write(.git/**)"
        ],
        "ask": [
            "Bash(git push *)",
            "Bash(npm publish *)",
            "Bash(docker build *)",
            "mcp__github__create_pull_request",
            "mcp__github__merge_pull_request"
        ]
    }
}
