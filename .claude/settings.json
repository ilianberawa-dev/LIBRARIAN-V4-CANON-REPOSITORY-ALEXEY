      "Bash(mkdir -p:*)",
      "Bash(chown:*)",
      "Bash(chmod 6*:*)",
      "Bash(chmod 7*:*)",
      "Bash(chmod 0*:*)",
      "Bash(chmod 4*:*)",
      "Bash(chmod 5*:*)",
      "Bash(chmod u+:*)",
      "Bash(chmod u-:*)",
      "Bash(chmod g+:*)",
      "Bash(chmod g-:*)",
      "Bash(chmod o-:*)",
      "Bash(chmod -R:*)",
      "Bash(touch:*)",
      "Bash(cp -r:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln -s:*)",
      "Bash(tar -tf:*)",
      "Bash(tar -xf:*)",
      "Bash(tar -czf:*)",
      "Bash(unzip -l:*)",
      "Bash(unzip:*)",
      "Bash(gzip -d:*)",
