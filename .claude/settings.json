      "Bash(sudo -u personal-assistant:*)",
      "Bash(sudo bash install*)",
      "Bash(sudo systemctl status:*)",
      "Bash(sudo systemctl is-active:*)",
      "Bash(sudo systemctl restart personal-assistant-*)",
      "Bash(sudo systemctl start personal-assistant-*)",
      "Bash(sudo systemctl stop personal-assistant-*)",
      "Bash(sudo systemctl enable personal-assistant-*)",
      "Bash(sudo systemctl daemon-reload)",
      "Bash(sudo journalctl:*)",
      "Bash(sudo install:*)",
      "Bash(sudo mkdir -p:*)",
      "Bash(sudo chown personal-assistant:*)",
      "Bash(sudo chmod:*)",
      "Bash(sudo cp:*)",
      "Bash(sudo cat:*)",
      "Bash(sudo ls:*)",
