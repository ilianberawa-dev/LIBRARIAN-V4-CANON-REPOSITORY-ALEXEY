      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -fr /:*)",
      "Bash(rm -fr /*)",
      "Bash(sudo rm -rf:*)",
      "Bash(sudo rm -fr:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git clean -ffd:*)",
      "Bash(git branch -D:*)",
      "Bash(git push origin --delete:*)",
      "Bash(git push :*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref -d:*)",

      "Bash(dd if=:*)",
      "Bash(dd of=:*)",
      "Bash(mkfs:*)",
      "Bash(mkfs.*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shred:*)",
      "Bash(:(){ :|:& };:)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",

      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(groupadd:*)",
      "Bash(groupdel:*)",
      "Bash(passwd:*)",
      "Bash(chpasswd:*)",
      "Bash(visudo:*)",

      "Bash(systemctl mask:*)",
      "Bash(systemctl disable personal-assistant-*)",
      "Bash(systemctl poweroff)",
      "Bash(systemctl reboot)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(init 0)",
      "Bash(init 6)",

      "Bash(sqlite3 * \"DROP *\")",
      "Bash(sqlite3 * \"DELETE FROM *\")",
      "Bash(sqlite3 * \"TRUNCATE *\")",

      "Bash(iptables:*)",
      "Bash(ufw:*)",
      "Bash(firewall-cmd:*)",

      "Bash(crontab -r:*)",

      "Bash(chmod 777 /:*)",
      "Bash(chown root:*)",
      "Bash(sudo chown root:*)"
    ],

    "defaultMode": "default"
  }
}
