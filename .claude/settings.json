{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Auto-allow common deploy/audit commands so agents don't pester Ilya for every operation. Destructive ops (rm -rf, force push, drop, etc.) stay in deny — those will still prompt. Edit Bash patterns carefully: `Bash(cmd:*)` matches any args.",

  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(pwd)",
      "Bash(hostname:*)",
      "Bash(whoami)",
      "Bash(id:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(tree:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(jq:*)",
      "Bash(xxd:*)",
      "Bash(md5sum:*)",
      "Bash(sha256sum:*)",
      "Bash(test:*)",
      "Bash([ *)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(git tag:*)",
      "Bash(git describe:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge --ff-only:*)",
      "Bash(git pull origin:*)",
      "Bash(git pull --rebase:*)",
