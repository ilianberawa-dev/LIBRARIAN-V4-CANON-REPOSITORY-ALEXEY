      "Bash(systemctl is-enabled:*)",
      "Bash(systemctl is-failed:*)",
      "Bash(systemctl list-units:*)",
      "Bash(systemctl list-unit-files:*)",
      "Bash(systemctl show:*)",
      "Bash(systemctl cat:*)",
      "Bash(journalctl:*)",
      "Bash(systemctl daemon-reload)",
      "Bash(systemctl enable personal-assistant-*)",
      "Bash(systemctl restart personal-assistant-*)",
      "Bash(systemctl start personal-assistant-*)",
      "Bash(systemctl stop personal-assistant-*)",
      "Bash(systemctl reload personal-assistant-*)",

      "Bash(ps:*)",
