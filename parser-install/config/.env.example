# Telegram Parser Environment Variables
# Copy to .env and fill with real values

# xAI Grok API for transcription ($0.10/hour audio)
# Get from: https://console.x.ai/team/api-keys
XAI_API_KEY=

# Telegram Bot for notifications (@BotFather)
# 1. Create bot: /newbot in @BotFather
# 2. Get token, paste here
BOT_TOKEN=

# Your Telegram chat ID (where to send notifications)
# Get from: send /start to @userinfobot
CHAT_ID=
