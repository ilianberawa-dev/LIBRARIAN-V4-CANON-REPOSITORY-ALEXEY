# Telegram Parser Cron Schedule
# Copy these lines to crontab: crontab -e

# Sync channel every 6 hours (detect new posts)
0 */6 * * * cd /opt/tg-export && node sync_channel.mjs >> sync.log 2>&1

# Heartbeat every 10 minutes (monitor + auto-restart)
*/10 * * * * cd /opt/tg-export && bash heartbeat.sh

# Notify progress every 2 hours
0 */2 * * * cd /opt/tg-export && bash notify.sh >> notify.log 2>&1

# Optional: GitHub sync every hour (if github-sync.sh configured)
0 * * * * cd /opt/librarian && bash github-sync.sh >> github-sync.log 2>&1

# Optional: Weekly verification (check downloads integrity)
0 3 * * 0 cd /opt/tg-export && bash verify.sh >> verify.log 2>&1
